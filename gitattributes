# Raaga Studio Pro — .gitattributes
# Rename this to .gitattributes in your repo root

# ── Git LFS for large sound files ──────────────────────────
# Uncomment these lines if you use Git LFS for the sounds/ folder
# (recommended for GitHub — WAV files are large)

# sounds/**/*.wav filter=lfs diff=lfs merge=lfs -text
# sounds/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
# sounds/**/*.ogg filter=lfs diff=lfs merge=lfs -text

# ── Line endings ────────────────────────────────────────────
# Ensure consistent line endings across platforms
*.html text eol=lf
*.md   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.txt  text eol=lf

# Binary files — no line ending conversion
*.wav  binary
*.mp3  binary
*.ogg  binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
